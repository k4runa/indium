CompileFlags:
  # Point clangd at the build dir's compile_commands.json (generated by CMake via
  # CMAKE_EXPORT_COMPILE_COMMANDS). This gives clangd the real per-file include
  # paths and flags, eliminating false "header not found" errors in the editor.
  CompilationDatabase: build-windows
  # Fallback include dirs for files not yet in the database (or before first build).
  Add:
    - "-Icore"
    - "-I2D"
    - "-I2D/component"
    - "-I2D/entity"
    - "-Iinclude"
    - "-Isrc"
    - "-I."
    - "-std=c++20"
    # raylib headers from the local shared-build install (see build-windows.sh)
    - "-I_raylib/install/include"
    # MSYS2 UCRT64 system headers
    - "-IC:/msys64/ucrt64/include"

# Turn off clangd's automatic / on-save formatting. With no .clang-format style
# defined clangd would impose LLVM style; DisableFormat keeps your layout intact.
Diagnostics:
  # Don't nag about headers that look unused — many engine headers are umbrella includes.
  UnusedIncludes: None
